# ============================================================================
# MCP Server Configuration - GitHub & Jira Integration
# ============================================================================
# Copy this file to .mcp.env and fill in your credentials
# NEVER commit .mcp.env to git - it contains secrets

# ============================================================================
# GitHub Configuration
# ============================================================================
# Get token: https://github.com/settings/tokens
# Permissions needed: repo, read:org, read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repository in format: owner/repo
GITHUB_REPOSITORY=utmcsj/cmms

# GitHub API URL (optional, for GitHub Enterprise)
GITHUB_API_URL=https://api.github.com

# ============================================================================
# Jira Configuration  
# ============================================================================
# Jira instance URL (e.g., https://your-company.atlassian.net)
JIRA_HOST=https://your-company.atlassian.net

# Email associated with Jira account
JIRA_EMAIL=your-email@example.com

# Get token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Project key (from your Jira project settings)
JIRA_PROJECT_KEY=CMMS

# ============================================================================
# Optional: Webhook Configuration
# ============================================================================
# For bi-directional sync between GitHub and Jira
GITHUB_WEBHOOK_SECRET=your-webhook-secret
JIRA_WEBHOOK_KEY=your-webhook-key
