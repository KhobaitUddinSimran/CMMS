{
  "version": "1.0.0",
  "description": "MCP Server configuration for CMMS project - GitHub and Jira integration",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "github-mcp-server"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "GITHUB_OWNER": "utmcsj",
        "GITHUB_REPO": "cmms"
      },
      "timeout": 30000,
      "description": "GitHub repository management and automation",
      "features": [
        "search_repositories",
        "list_issues",
        "create_issue",
        "list_pull_requests",
        "create_pull_request",
        "search_code",
        "get_file_contents"
      ]
    },
    "jira": {
      "command": "npx",
      "args": ["-y", "jira-mcp-server"],
      "env": {
        "JIRA_HOST": "${JIRA_HOST}",
        "JIRA_EMAIL": "${JIRA_EMAIL}",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}",
        "JIRA_PROJECT_KEY": "CMMS"
      },
      "timeout": 30000,
      "description": "Jira project management and issue tracking",
      "features": [
        "get_issues",
        "create_issue",
        "update_issue",
        "get_sprints",
        "get_board",
        "search_users",
        "add_comment",
        "transition_issue"
      ]
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "supabase-mcp-server"],
      "env": {
        "SUPABASE_URL": "https://dvrvotajdelswvdxkuyt.supabase.co",
        "SUPABASE_SERVICE_ROLE_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImR2cnZvdGFqZGVsc3d2ZHhrdXl0Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTcwODAwMDAwMCwiZXhwIjo5OTk5OTk5OTk5fQ.mock_token"
      },
      "timeout": 30000,
      "description": "Supabase database and backend management",
      "features": [
        "execute_sql",
        "list_tables",
        "get_table_schema",
        "run_migrations",
        "manage_auth",
        "list_functions",
        "deploy_functions"
      ]
    }
  },
  "serverOrder": ["github", "jira", "supabase"],
  "logging": {
    "enabled": true,
    "level": "info",
    "file": ".mcp_debug.log"
  },
  "features": {
    "autoConnect": true,
    "healthCheck": {
      "enabled": true,
      "interval": 3600000
    },
    "retryPolicy": {
      "maxRetries": 3,
      "backoffMs": 1000
    }
  }
}
