# Supabase Configuration
# Get from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-public-key>
# Service role key – bypasses RLS; required for server-side writes
SUPABASE_SERVICE_KEY=<service-role-key>
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# JWT Configuration
# In production use a long random string (Render can auto-generate via generateValue: true)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_LOGIN=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM_ADDRESS=your-gmail@gmail.com
EMAIL_FROM_NAME=CMMS – UTM

# Application Configuration
# Use "production" on Render; "development" locally
ENVIRONMENT=development

# CORS – comma-separated list of allowed origins
# In production set to your Render frontend URL, e.g.:
# CORS_ORIGINS=https://cmms-frontend.onrender.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
