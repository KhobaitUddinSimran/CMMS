# CMMS Environment Variables Template
# Copy to .env and customize for your environment

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://cmms_user:cmms_password_dev_only@localhost:5432/cmms_production
DB_ECHO=false
DB_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# JWT
JWT_SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# CORS
ORIGINS=http://localhost:3000,http://localhost

# Email (console, resend, mailgun)
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@cmms.example.com

# Anthropic (optional)
ANTHROPIC_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CMMS
